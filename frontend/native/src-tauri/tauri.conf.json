{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "POS Register",
  "version": "0.1.0",
  "identifier": "com.bellesoftsystems.pos.register",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:5174"
  },
  "app": {
    "windows": [
      {
        "title": "POS Register",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; form-action 'self'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
