# .env.prod.example — production stack (`make prod-up`, compose.prod.yml).
# Copy to `.env` in this same directory (gitignored) and fill in. Compose reads
# `.env` from the directory it's invoked from — keep it beside compose.prod.yml.
#
# Note: compose.prod.yml's `name: pos` means it claims the `pos_pgdata` volume
# outright — if this host ever ran another stack named `pos` (e.g. the retired
# infra/docker-compose.yml), tear it down with `-v` first or boot this one
# with COMPOSE_PROJECT_NAME=<something-else> to avoid attaching to that data.

# Postgres password for the prod db container. Pick a real secret — this isn't
# dev's throwaway "pos" default.
POS_DB_PASSWORD=

# Laravel APP_KEY. Mint one with `make dev-key` (builds the dev api image and
# runs `artisan key:generate --show` against it — the key format doesn't
# depend on env/prod) and paste the `base64:...` value here.
POS_APP_KEY=

# Public hostname for the register app + API. Needs DNS pointing at this host
# and 80/443 reachable from the internet for ACME (POS_TLS_ISSUER=acme below)
# to issue a real certificate. For a domainless local smoke test, use
# register.localhost (resolves to 127.0.0.1 with no /etc/hosts edit) together
# with POS_TLS_ISSUER=internal.
POS_REGISTER_DOMAIN=

# Public hostname for the back-office app. Same DNS/reachability requirement
# as POS_REGISTER_DOMAIN; admin.localhost for the domainless smoke test.
POS_ADMIN_DOMAIN=

# ISO 4217 currency code this business trades in (e.g. USD). Required — the
# app refuses to boot without it (see backend/docker/entrypoint.sh).
POS_CURRENCY=

# Legal/trading name printed on receipts and the Z-report.
POS_BUSINESS_NAME=

# --- Optional -----------------------------------------------------------

# Printed on receipts if set. Blank is fine.
POS_BUSINESS_ADDRESS=

# Tax/VAT registration id printed on receipts if set. Blank is fine.
POS_BUSINESS_TAX_ID=

# Certificate issuer for Caddy's automatic TLS. Default is "acme" — real
# certificates from Let's Encrypt, requiring DNS + reachable 80/443. Set to
# "internal" for a domainless local boot (register.localhost/admin.localhost):
# Caddy mints from its own local CA instead, so curl needs -k.
# POS_TLS_ISSUER=acme

# Run `php artisan migrate --force` on every api container boot. Default is 1
# (on) — set to 0 once you'd rather run migrations by hand.
# POS_MIGRATE_ON_BOOT=1
