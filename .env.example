# Root .env — consumed by compose.dev.yml (`make dev`). Copy to `.env` (gitignored)
# and fill in. Never committed — this is documentation of the shape only.

# Postgres port on the HOST. Default 5432. Override if something else already
# binds it locally (e.g. this machine's native infra/docker-compose.yml Postgres
# on 5433 — leave that one running and pick a free port here instead, such as 5434).
POS_DEV_DB_PORT=5432

# Postgres password, dev only. The container default (below) is fine unless you
# have a reason to change it.
POS_DEV_DB_PASSWORD=pos

# Laravel APP_KEY for the compose stack. Mint one from the api dev image
# (built by Task 1/2's backend/Dockerfile). The dev stage has no app code
# baked in — it arrives via bind mount at runtime — so `artisan` isn't present
# in the bare image; bind-mount backend/ (which has vendor/ installed) to run
# it once:
#   docker run --rm -v "$(pwd)/backend:/app" pos-api:dev php artisan key:generate --show
POS_DEV_APP_KEY=

# --- Optional: host port overrides -----------------------------------------
# compose.dev.yml maps api/web/back-office to 8000/5174/5175 by default. If a
# native `php artisan serve` or `npm run dev` from an earlier session already
# holds one of those ports on this machine, override the host side here rather
# than stopping the native process — the container still listens on its usual
# port internally.
# POS_DEV_API_PORT=8000
# POS_DEV_WEB_PORT=5174
# POS_DEV_BACKOFFICE_PORT=5175
